---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Japanese Word Rank Lookup" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Look up Japanese word frequency rankings across multiple datasets. Search by kana, kanji, or romaji." />
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>

    <!-- Google Fonts: Nunito (English fallback), Noto Sans JP, Zen Maru Gothic, Klee One -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Klee+One&family=Noto+Sans+JP:wght@300;400;500;700&family=Nunito:wght@400;600;700&family=Zen+Maru+Gothic:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem("theme");
        if (stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased px-2" style="font-family: var(--font-english);">
    <slot />

    <!-- Footer -->
    <footer class="border-t border-border mt-8">
      <div class="max-w-5xl mx-auto px-6 py-8">
        <div class="flex flex-wrap gap-x-8 sm:gap-x-16 gap-y-6 text-sm">
          <!-- Internal pages -->
          <div>
            <h3 class="font-bold text-foreground mb-2">Pages</h3>
            <ul class="space-y-1 text-muted-foreground">
              <li><a href="/about" class="hover:text-foreground transition-colors">About + Credits</a></li>
              <li><a href="/faq" class="hover:text-foreground transition-colors">FAQ</a></li>
              <li><a href="/privacy" class="hover:text-foreground transition-colors">Privacy Policy</a></li>
              <li><a href="/terms" class="hover:text-foreground transition-colors">Terms of Use</a></li>
            </ul>
          </div>

          <!-- External pages -->
          <div>
            <h3 class="font-bold text-foreground mb-2">Projects</h3>
            <ul class="space-y-1 text-muted-foreground">
              <li><a href="https://kanjiheatmap.com?utm_source=jp-word" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">🔥 Kanji Heatmap</a></li>
              <li><a href="https://ririkku.com?utm_source=jp-word" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">🎤 Ririkku</a></li>
            </ul>
          </div>

          <!-- Socials -->
          <div>
            <h3 class="font-bold text-foreground mb-2">Socials</h3>
            <ul class="space-y-1 text-muted-foreground">
              <li><a href="https://github.com/PikaPikaGems/" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">🐙 GitHub</a></li>
              <li><a href="https://www.instagram.com/pikapikagems" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">📷 Instagram</a></li>
              <li><a href="https://discord.gg/Ash8ZrGb4s" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">💬 Discord</a></li>
              <li><a href="https://x.com/pikapikagemsjp" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">🐦 Twitter</a></li>
            </ul>
          </div>

          <!-- Theme toggle -->
          <div class="ml-auto flex items-start">
            <button
              id="theme-toggle"
              class="inline-flex items-center gap-2 rounded-full border border-input bg-background px-4 py-2 text-sm font-medium text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer"
              title="Toggle dark/light theme"
            >
              <svg class="theme-icon-sun hidden h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              <svg class="theme-icon-moon h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
              <span class="theme-label">Dark mode</span>
            </button>
          </div>
        </div>

        </div>
    </footer>

    <script is:inline>
      (function() {
        const btn = document.getElementById("theme-toggle");
        const sunIcons = document.querySelectorAll(".theme-icon-sun");
        const moonIcons = document.querySelectorAll(".theme-icon-moon");
        const label = btn.querySelector(".theme-label");

        function update() {
          const isDark = document.documentElement.classList.contains("dark");
          sunIcons.forEach(el => el.classList.toggle("hidden", !isDark));
          moonIcons.forEach(el => el.classList.toggle("hidden", isDark));
          label.textContent = isDark ? "Light mode" : "Dark mode";
        }

        btn.addEventListener("click", () => {
          document.documentElement.classList.toggle("dark");
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
          update();
        });

        update();
      })();
    </script>

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/' });
        });
      }
    </script>
  </body>
</html>
