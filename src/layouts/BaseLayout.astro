---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Japanese Word Rank Lookup" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Look up Japanese word frequency rankings across multiple datasets. Search by kana, kanji, or romaji." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Google Fonts: Nunito (English fallback), Noto Sans JP, Zen Maru Gothic, Klee One -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Klee+One&family=Noto+Sans+JP:wght@300;400;500;700&family=Nunito:wght@400;600;700&family=Zen+Maru+Gothic:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased" style="font-family: var(--font-english);">
    <slot />
  </body>
</html>
