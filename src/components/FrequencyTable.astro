---
import { DATASET_CATALOG } from "../lib/dataset-catalog";
import { TIER_STYLE } from "../lib/badges";

const unrankedBadge = TIER_STYLE.UNRANKED.badge;
---

<style>
  @keyframes accordion-expand {
    from { opacity: 0; transform: translateY(-20px) scaleY(0.8); }
    to { opacity: 1; transform: translateY(0) scaleY(1); }
  }
  @keyframes accordion-collapse {
    from { opacity: 1; transform: translateY(0) scaleY(1); }
    to { opacity: 0; transform: translateY(-20px) scaleY(0.8); }
  }
  details[open] > div {
    animation: accordion-expand 0.4s cubic-bezier(0.34, 1.4, 0.64, 1) both;
    transform-origin: top;
  }
  details > div.collapsing {
    animation: accordion-collapse 0.3s ease-in both;
    transform-origin: top;
  }
</style>

<div class="space-y-4">
  {DATASET_CATALOG.map((section, sectionIndex) => (
    <details class="group rounded-2xl border border-border" open={sectionIndex === 0}>
      <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-bold text-foreground hover:bg-muted/50 transition-colors select-none list-none [&::-webkit-details-marker]:hidden">
        <span>{section.title}</span>
        <svg class="h-4 w-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </summary>

      <div class="border-t border-border px-5 pb-5 pt-4 space-y-6">
        {section.subsections.map((sub) => (
          <div>
            {sub.title && (
              <h3 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-3">
                {sub.title}
              </h3>
            )}

            <div class="rounded-xl border border-border overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-border bg-muted/50">
                      <th class="py-3 px-3 sm:px-5 text-left text-sm font-semibold text-muted-foreground w-20 sm:w-28">Tier</th>
                      <th class="py-3 px-3 sm:px-5 text-right text-sm font-semibold text-muted-foreground w-16 sm:w-24">Rank</th>
                      <th class="py-3 px-3 sm:px-5 text-left text-sm font-semibold text-muted-foreground w-32 sm:w-44 md:w-52">Dataset</th>
                      <th class="py-3 px-3 sm:px-5 text-left text-sm font-semibold text-muted-foreground min-w-32 sm:min-w-48">Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {sub.datasets.map((dataset, i) => {
                      const stripe = i % 2 === 1 ? "bg-muted/30" : "";
                      const dimmed = dataset.notRecommended ? "opacity-50" : "";
                      return (
                        <tr data-column-id={dataset.columnId} class={`border-b border-border last:border-0 transition-colors hover:bg-muted/50 ${dimmed} ${stripe}`}>
                          <td class=" px-3 sm:px-5 align-middle">
                            <span data-tier-badge class={`inline-flex items-center rounded-full border px-2 sm:px-3 py-1 text-xs font-bold ${unrankedBadge}`}>
                              UNRANKED
                            </span>
                          </td>
                          <td data-rank-cell class="py-2.5 px-3 sm:px-5 align-middle text-right tabular-nums text-sm text-muted-foreground/40">
                          <!-- TODO: Instead of tier BASIC, COMMON, FLUENT, ADVANCED, can we put emojis instead? 🌱, ☘️, 🌷, 📚, 🦉  see also badges.ts file-->
                            —
                          </td>
                          <td class="py-2.5 sm:px-5 align-middle min-w-42 sm:min-w-60">
                            <code class="text-xs sm:text-sm bg-muted px-1.5 sm:px-2.5 py-1  rounded-lg break-all">
                              {dataset.columnId}
                            </code>
                          </td>
                          <td class="px-3 sm:px-5 align-middle py-4 text-muted-foreground text-xs sm:text-sm min-w-64 sm:min-w-48">
                            {dataset.description}
                            {dataset.notRecommended && (
                              <span class="ml-1 text-amber-600 font-medium">⚠ Not recommended</span>
                            )}
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        ))}
      </div>
    </details>
  ))}
</div>

<script>
  document.querySelectorAll<HTMLDetailsElement>("details").forEach((details) => {
    const summary = details.querySelector("summary");
    const content = details.querySelector<HTMLElement>(":scope > div");
    if (!summary || !content) return;

    summary.addEventListener("click", (e) => {
      if (!details.open) return; // opening — let browser handle normally
      e.preventDefault();
      content.classList.add("collapsing");
      content.addEventListener("animationend", () => {
        content.classList.remove("collapsing");
        details.open = false;
      }, { once: true });
    });
  });
</script>
