---
/**
 * Frequency data table — shadcn/ui Table aesthetic.
 * Accordion sections (HTML details/summary), subsection headings, bordered table rows.
 */

import { DATASET_CATALOG } from "../lib/dataset-catalog";
import { getTier } from "../lib/tier";
import type { Tier } from "../lib/tier";

interface Props {
  ranks: Record<string, number>;
  ririkkuRanks?: Record<string, number>;
}

const { ranks, ririkkuRanks = {} } = Astro.props;

function getRank(columnId: string): number {
  if (columnId in ranks) return ranks[columnId];
  const ririkkuKey = columnId === "CC100_rank" ? "CC100" : columnId;
  if (ririkkuKey in ririkkuRanks) return ririkkuRanks[ririkkuKey];
  return -1;
}

const tierBadge: Record<Tier, string> = {
  BASIC:    "bg-emerald-50 text-emerald-700 border-emerald-200",
  COMMON:   "bg-blue-50 text-blue-700 border-blue-200",
  FLUENT:   "bg-violet-50 text-violet-700 border-violet-200",
  ADVANCED: "bg-amber-50 text-amber-700 border-amber-200",
  UNRANKED: "bg-gray-50 text-gray-400 border-gray-200",
};
---

<div class="space-y-4">
  {DATASET_CATALOG.map((section, sectionIndex) => (
    <details class="group rounded-lg border border-border" open={sectionIndex === 0}>
      <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-foreground hover:bg-muted/50 transition-colors select-none list-none [&::-webkit-details-marker]:hidden">
        <span>{section.title}</span>
        <svg class="h-4 w-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </summary>

      <div class="border-t border-border px-4 pb-4 pt-3 space-y-5">
        {section.subsections.map((sub) => (
          <div>
            {sub.title && (
              <h3 class="text-xs font-medium uppercase tracking-widest text-muted-foreground mb-2">
                {sub.title}
              </h3>
            )}

            <div class="rounded-md border border-border overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-border bg-muted/50">
                      <th class="h-9 px-3 text-left text-xs font-medium text-muted-foreground w-24">Tier</th>
                      <th class="h-9 px-3 text-left text-xs font-medium text-muted-foreground w-48">Dataset</th>
                      <th class="h-9 px-3 text-right text-xs font-medium text-muted-foreground w-20">Rank</th>
                      <th class="h-9 px-3 text-left text-xs font-medium text-muted-foreground">Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {sub.datasets.map((dataset, i) => {
                      const rank = getRank(dataset.columnId);
                      const tier = getTier(rank);
                      const isAbsent = rank === -1;
                      const dimmed = dataset.notRecommended ? "opacity-50" : "";
                      const stripe = i % 2 === 1 ? "bg-muted/30" : "";

                      return (
                        <tr class={`border-b border-border last:border-0 transition-colors hover:bg-muted/50 ${dimmed} ${stripe}`}>
                          <td class="h-9 px-3 align-middle">
                            <span class={`inline-flex items-center rounded-md border px-2 py-0.5 text-[10px] font-semibold ${tierBadge[tier]}`}>
                              {tier}
                            </span>
                          </td>
                          <td class="h-9 px-3 align-middle">
                            <code class="text-xs bg-muted px-1.5 py-0.5 rounded font-mono">
                              {dataset.columnId}
                            </code>
                          </td>
                          <td class={`h-9 px-3 align-middle text-right font-mono tabular-nums ${isAbsent ? "text-muted-foreground/40" : "font-semibold text-foreground"}`}>
                            {isAbsent ? "—" : rank.toLocaleString()}
                          </td>
                          <td class="h-9 px-3 align-middle text-muted-foreground text-xs">
                            {dataset.description}
                            {dataset.notRecommended && (
                              <span class="ml-1 text-amber-600 font-medium">⚠ Not recommended</span>
                            )}
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        ))}
      </div>
    </details>
  ))}
</div>
