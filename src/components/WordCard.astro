---
import { DICTIONARY_LINKS } from "../lib/external-links";
---

<style>
  @keyframes card-fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .word-card {
    animation: card-fade-in 0.5s cubic-bezier(0.34, 1.4, 0.64, 1) both;
  }
  .book-popover:not(.hidden) {
    transition:
      opacity 0.35s ease-out,
      transform 0.5s cubic-bezier(0.34, 1.8, 0.64, 1);
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  @starting-style {
    .book-popover:not(.hidden) {
      opacity: 0;
      transform: translateY(-24px) scale(0.6);
    }
  }
</style>

<div class="word-card rounded-2xl border border-border  text-card-foreground shadow-sm relative hover:bg-green-500/5">
  <div class="absolute top-3 right-4 flex items-center gap-1">
    <span data-rank-label class="text-xs font-bold text-muted-foreground tabular-nums"></span>
    <span data-tier-emoji class="text-sm leading-none"></span>
  </div>
  <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-5 p-4 sm:p-6">

    <!-- Icon buttons column -->
    <div class="flex flex-row sm:flex-col gap-2.5 shrink-0 order-3 sm:order-1">
      <button class="tts-btn inline-flex h-10 w-10 items-center justify-center rounded-xl border border-input bg-background text-muted-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer" data-word="" title="Listen to pronunciation">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/></svg>
      </button>
      <div class="relative inline-block">
        <button class="book-btn inline-flex h-10 w-10 items-center justify-center rounded-xl border border-input bg-background text-muted-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer" title="Dictionary links" aria-expanded="false" data-book-trigger>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </button>
        <div class="book-popover hidden absolute z-50 top-full left-0 mt-2 w-56 rounded-xl border border-border bg-popover p-4 text-popover-foreground shadow-md" data-book-popover>
          <div class="absolute -top-1.5 left-3 h-3 w-3 rotate-45 border-l border-t border-border bg-popover"></div>
          <p class="text-xs font-bold text-muted-foreground mb-2">Look up in:</p>
          <div class="flex flex-col gap-1">
            {DICTIONARY_LINKS.map((d) => (
              <a data-dict-name={d.name} href="" target="_blank" rel="noopener noreferrer" class="text-sm text-foreground hover:text-primary transition-colors no-underline hover:underline">
                {d.name}
              </a>
            ))}
          </div>
        </div>
      </div>
      <button class="copy-url-btn inline-flex h-10 w-10 items-center justify-center rounded-xl border border-input bg-background text-muted-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer" data-copy-url="" title="Copy link to word">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>

    <!-- Word display -->
    <div class="shrink-0 sm:py-4 order-1 sm:order-2">
      <span data-word-display class="block text-5xl sm:text-7xl font-bold text-foreground sm:px-6 leading-tight" style="font-family: var(--font-japanese);"></span>
      <span data-word-reading class="block text-lg text-muted-foreground mt-1.5 sm:px-6" style="font-family: var(--font-japanese);"></span>
    </div>

    <!-- Badges -->
    <div data-badges class="flex flex-wrap gap-2 content-start sm:flex-1 min-w-0 sm:py-8 order-2 sm:order-3"></div>

  </div>
</div>
