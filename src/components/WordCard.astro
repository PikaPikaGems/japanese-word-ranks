---
/**
 * Word card — matches the NOTES.md wireframe layout:
 * [iconC] [iconD]  |  BIG_JAPANESE_WORD  |  [badges...]
 *                  |  reading            |
 */

import BadgeWithPopover from "./BadgeWithPopover.astro";
import { getTier } from "../lib/tier";
import { SORT_ORDER_MAP } from "../lib/sort-orders";
import { DICTIONARY_LINKS } from "../lib/external-links";
import type { Tier } from "../lib/tier";

interface BadgeData {
  label: string;
  value: string | number;
  tier: Tier;
  description: string;
}

interface Props {
  word: string;
  hiragana: string;
  katakana: string;
  jlptLevel?: number;
  isKaishi?: boolean;
  ranks: Record<string, number>;
  linked?: boolean;
}

const { word, hiragana, katakana, jlptLevel, isKaishi, ranks, linked = false } = Astro.props;

// Build badge data
const badges: BadgeData[] = [];

if (jlptLevel) {
  badges.push({
    label: "JLPT",
    value: `N${jlptLevel}`,
    tier: jlptLevel >= 4 ? "BASIC" : jlptLevel === 3 ? "COMMON" : jlptLevel === 2 ? "FLUENT" : "ADVANCED",
    description: `Japanese Language Proficiency Test Level N${jlptLevel}`,
  });
}

if (isKaishi) {
  badges.push({
    label: "Kaishi",
    value: "✓",
    tier: "BASIC",
    description: "This word is in the Kaishi 1500 beginner vocabulary deck.",
  });
}

const frequencyKeys = Object.keys(ranks);
for (const key of frequencyKeys) {
  const rank = ranks[key];
  const sortOrder = SORT_ORDER_MAP.get(key);
  if (!sortOrder) continue;
  badges.push({
    label: sortOrder.label,
    value: rank,
    tier: getTier(rank),
    description: sortOrder.description,
  });
}

const wordUrl = `/word/?w=${encodeURIComponent(word)}`;
---

<div class="rounded-2xl border border-border bg-card text-card-foreground shadow-sm">
  <div class="flex items-start gap-5 p-6 sm:p-7">
    <!-- Icon buttons column (iconC, iconD) -->
    <div class="flex flex-col gap-2.5 pt-1 shrink-0">
      <button
        class="tts-btn inline-flex h-10 w-10 items-center justify-center rounded-xl border border-input bg-background text-muted-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer"
        data-word={word}
        title="Listen to pronunciation"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/></svg>
      </button>
      <span class="relative inline-block">
        <button
          class="book-btn inline-flex h-10 w-10 items-center justify-center rounded-xl border border-input bg-background text-muted-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer"
          data-word={word}
          title="Dictionary links"
          aria-expanded="false"
          data-book-trigger
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </button>
        <div
          class="book-popover hidden absolute z-50 top-full left-0 mt-2 w-56 rounded-xl border border-border bg-popover p-4 text-popover-foreground shadow-md"
          data-book-popover
        >
          <div class="absolute -top-1.5 left-3 h-3 w-3 rotate-45 border-l border-t border-border bg-popover"></div>
          <p class="text-xs font-bold text-muted-foreground mb-2">Look up in:</p>
          <div class="flex flex-col gap-1">
            {DICTIONARY_LINKS.map((d) => (
              <a href={d.url(word)} target="_blank" rel="noopener noreferrer" class="text-sm text-foreground hover:text-primary transition-colors no-underline hover:underline">
                {d.name}
              </a>
            ))}
          </div>
        </div>
      </span>
      <button
        class="copy-url-btn inline-flex h-10 w-10 items-center justify-center rounded-xl border border-input bg-background text-muted-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer"
        data-copy-url={wordUrl}
        title="Copy link to word"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>

    <!-- Big word -->
    <div class="shrink-0">
      {linked ? (
        <a href={wordUrl} class="block text-5xl sm:text-7xl font-bold text-foreground hover:text-primary/80 transition-colors leading-tight" style="font-family: var(--font-japanese);">
          {word}
        </a>
      ) : (
        <span class="block text-5xl sm:text-7xl font-bold text-foreground leading-tight" style="font-family: var(--font-japanese);">
          {word}
        </span>
      )}
      {hiragana !== word && (
        <span class="block text-lg text-muted-foreground mt-1.5" style="font-family: var(--font-japanese);">
          {hiragana}
        </span>
      )}
    </div>

    <!-- Badges column -->
    <div class="flex flex-wrap gap-2 content-start flex-1 min-w-0 pt-1">
      {badges.map((badge) => (
        <BadgeWithPopover
          label={badge.label}
          value={badge.value}
          tier={badge.tier}
          description={badge.description}
        />
      ))}
    </div>
  </div>
</div>

<script>
  document.addEventListener("click", (e) => {
    // Copy URL
    const copyBtn = (e.target as HTMLElement).closest(".copy-url-btn") as HTMLElement | null;
    if (copyBtn) {
      const path = copyBtn.dataset.copyUrl;
      if (path) {
        const fullUrl = window.location.origin + path;
        navigator.clipboard.writeText(fullUrl).then(() => {
          const original = copyBtn.innerHTML;
          copyBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
          setTimeout(() => { copyBtn.innerHTML = original; }, 1500);
        });
      }
      return;
    }

    const ttsBtn = (e.target as HTMLElement).closest(".tts-btn");
    if (ttsBtn) {
      const word = (ttsBtn as HTMLElement).dataset.word;
      if (word && "speechSynthesis" in window) {
        const utterance = new SpeechSynthesisUtterance(word);
        utterance.lang = "ja-JP";
        speechSynthesis.speak(utterance);
      }
    }

    const bookTrigger = (e.target as HTMLElement).closest("[data-book-trigger]");

    // Close all book popovers (unless clicking the one being toggled)
    document.querySelectorAll("[data-book-popover]").forEach((el) => {
      if (bookTrigger && el === bookTrigger.parentElement?.querySelector("[data-book-popover]")) return;
      el.classList.add("hidden");
      el.parentElement?.querySelector("[data-book-trigger]")?.setAttribute("aria-expanded", "false");
    });

    if (bookTrigger) {
      const popover = bookTrigger.parentElement?.querySelector("[data-book-popover]") as HTMLElement | null;
      if (popover) {
        const isHidden = popover.classList.toggle("hidden");
        bookTrigger.setAttribute("aria-expanded", String(!isHidden));
      }
    }
  });
</script>
