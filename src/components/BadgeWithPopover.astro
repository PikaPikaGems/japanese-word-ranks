---
/**
 * Badge with popover — shadcn/ui aesthetic.
 * Rounded-md, color-coded by tier, click to show popover.
 */

import type { Tier } from "../lib/tier";

interface Props {
  label: string;
  value: string | number;
  tier?: Tier;
  description?: string;
}

const { label, value, tier = "UNRANKED", description = "" } = Astro.props;

const tierStyles: Record<string, { badge: string; emoji: string }> = {
  BASIC:    { badge: "bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100", emoji: "🌱" },
  COMMON:   { badge: "bg-blue-50 text-blue-700 border-blue-200 hover:bg-blue-100", emoji: "☘️" },
  FLUENT:   { badge: "bg-violet-50 text-violet-700 border-violet-200 hover:bg-violet-100", emoji: "🌷" },
  ADVANCED: { badge: "bg-amber-50 text-amber-700 border-amber-200 hover:bg-amber-100", emoji: "📚" },
  UNRANKED: { badge: "bg-gray-50 text-gray-500 border-gray-200 hover:bg-gray-100", emoji: "🦉" },
};

const style = tierStyles[tier] ?? tierStyles.UNRANKED;
const displayValue = value === -1 || value === "-1" ? "—" : value;
const uniqueId = `popover-${label.replace(/\s+/g, "-")}-${Math.random().toString(36).slice(2, 6)}`;
---

<span class="relative inline-block">
  <button
    class={`inline-flex items-center gap-1.5 rounded-md border px-2.5 py-0.5 text-xs font-semibold transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ${style.badge}`}
    aria-expanded="false"
    aria-controls={uniqueId}
    data-badge-trigger
  >
    <span class="text-xs">{style.emoji}</span>
    <span>{label}</span>
    <span class="font-bold">{displayValue}</span>
  </button>
  {description && (
    <div
      id={uniqueId}
      class="badge-popover hidden absolute z-50 top-full mt-2 w-72 rounded-lg border border-border bg-popover p-4 text-popover-foreground shadow-md"
      data-badge-popover
    >
      <div class="popover-arrow absolute -top-1.5 h-3 w-3 rotate-45 border-l border-t border-border bg-popover"></div>
      <p class="text-sm font-semibold mb-1">{label}</p>
      <p class="text-xs text-muted-foreground leading-relaxed">{description}</p>
    </div>
  )}
</span>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }
  .badge-popover:not(.hidden) {
    animation: fade-in 0.12s ease-out;
  }
</style>

<script>
  function initBadgePopovers() {
    document.addEventListener("click", (e) => {
      const trigger = (e.target as HTMLElement).closest("[data-badge-trigger]");

      // Close all popovers
      document.querySelectorAll("[data-badge-popover]").forEach((el) => {
        if (trigger && el.id === trigger.getAttribute("aria-controls")) return;
        el.classList.add("hidden");
        const btn = document.querySelector(`[aria-controls="${el.id}"]`);
        btn?.setAttribute("aria-expanded", "false");
      });

      // Toggle clicked
      if (trigger) {
        const id = trigger.getAttribute("aria-controls");
        const popover = id ? document.getElementById(id) : null;
        if (popover) {
          const isHidden = popover.classList.toggle("hidden");
          trigger.setAttribute("aria-expanded", String(!isHidden));

          // Position popover: default left-aligned, flip to right if it overflows
          if (!isHidden) {
            const arrow = popover.querySelector<HTMLElement>(".popover-arrow");
            // Reset to left-aligned first to measure
            popover.style.left = "0";
            popover.style.right = "auto";
            if (arrow) { arrow.style.left = "1rem"; arrow.style.right = "auto"; }

            const rect = popover.getBoundingClientRect();
            if (rect.right > window.innerWidth - 8) {
              popover.style.left = "auto";
              popover.style.right = "0";
              if (arrow) { arrow.style.left = "auto"; arrow.style.right = "1rem"; }
            }
          }
        }
      }
    });
  }
  initBadgePopovers();
</script>
