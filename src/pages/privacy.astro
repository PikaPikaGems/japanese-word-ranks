---
import BaseLayout from "../layouts/BaseLayout.astro";
import TitleHeader from "../components/TitleHeader.astro";
---

<BaseLayout title="Privacy Policy — Japanese Word Rank Lookup">
  <TitleHeader />
  <main class="page-content max-w-3xl mx-auto px-6 pt-18 pb-16">
    <h1 class="text-2xl font-bold mb-6">Privacy Policy</h1>
    <p class="text-sm text-muted-foreground mb-2">Effective: March 2026</p>

    <h2 class="text-sm font-bold mt-6 mb-2">Analytics</h2>
    <p class="text-sm text-muted-foreground mb-4">
      We use <a href="https://www.goatcounter.com/" class="underline hover:text-foreground">GoatCounter</a>, a privacy-friendly, open-source analytics tool. GoatCounter does not use cookies, does not collect personal data, and does not track users across sites. It only records anonymous, aggregate page view counts. See <a href="https://www.goatcounter.com/help/privacy" class="underline hover:text-foreground">GoatCounter's privacy policy</a> for details.
    </p>

    <h2 class="text-sm font-bold mt-6 mb-2">Local Storage</h2>
    <p class="text-sm text-muted-foreground mb-4">
      The site stores your theme preference (light/dark) in your browser's local storage. This data never leaves your device.
    </p>

    <h2 class="text-sm font-bold mt-6 mb-2">Third-Party Services</h2>
    <p class="text-sm text-muted-foreground mb-4">
      Google Fonts are loaded from Google's servers. Google may collect standard web request data (IP address, browser info) when serving fonts. See <a href="https://policies.google.com/privacy" class="underline hover:text-foreground">Google's Privacy Policy</a> for details.
    </p>

    <h2 class="text-sm font-bold mt-6 mb-2">Changes</h2>
    <p class="text-sm text-muted-foreground">
      If this policy changes, updates will be posted on this page.
    </p>
  </main>
</BaseLayout>
