---
/**
 * Word detail page.
 * Generates one static page per word from RIRIKKU_CONSOLIDATED.csv (~92k pages).
 * Shows word card + full frequency table.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import TitleHeader from "../../components/TitleHeader.astro";
import WordCard from "../../components/WordCard.astro";
import FrequencyTable from "../../components/FrequencyTable.astro";
import { loadRirikkuData, loadConsolidatedData, loadJlptData, loadKaishiData } from "../../lib/data-loader";

export async function getStaticPaths() {
  const ririkku = loadRirikkuData();
  const jlpt = loadJlptData();
  const kaishi = loadKaishiData();
  const consolidated = loadConsolidatedData();

  return ririkku.map((entry) => {
    const consKey = `${entry.word}|${entry.hiragana}`;
    const consData = consolidated.get(consKey);

    return {
      params: { slug: entry.word },
      props: {
        word: entry.word,
        hiragana: entry.hiragana,
        katakana: entry.katakana,
        jlptLevel: jlpt.get(entry.word),
        isKaishi: kaishi.wordSet.has(entry.word),
        ririkkuRanks: entry.ranks,
        consolidatedRanks: consData?.ranks ?? {},
      },
    };
  });
}

interface Props {
  word: string;
  hiragana: string;
  katakana: string;
  jlptLevel?: number;
  isKaishi?: boolean;
  ririkkuRanks: Record<string, number>;
  consolidatedRanks: Record<string, number>;
}

const { word, hiragana, katakana, jlptLevel, isKaishi, ririkkuRanks, consolidatedRanks } = Astro.props;
const pageTitle = `${word} — Japanese Word Frequency`;
---

<BaseLayout title={pageTitle}>
  <TitleHeader />
  <main class="max-w-5xl mx-auto px-4 pt-16 pb-16">
    <!-- Word Card -->
    <div class="mt-6 mb-8">
      <WordCard
        word={word}
        hiragana={hiragana}
        katakana={katakana}
        jlptLevel={jlptLevel}
        isKaishi={isKaishi}
        ranks={ririkkuRanks}
        linked={false}
      />
    </div>

    <!-- Frequency Table -->
    <FrequencyTable
      ranks={consolidatedRanks}
      ririkkuRanks={ririkkuRanks}
    />
  </main>
</BaseLayout>
