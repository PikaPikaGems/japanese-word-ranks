---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TitleHeader from "../../components/TitleHeader.astro";
import SearchInput from "../../components/SearchInput.astro";
import WordCardSkeleton from "../../components/WordCardSkeleton.astro";
import WordCard from "../../components/WordCard.astro";
import FrequencyTable from "../../components/FrequencyTable.astro";
---

<BaseLayout title="Word Detail — Japanese Word Frequency">
  <TitleHeader />
  <main class="max-w-5xl mx-auto pt-6 pb-16">
    <SearchInput />
    <!-- Loading state -->
    <div id="loading-spinner" class="flex items-center justify-center h-[1000px]">
      <div class="h-6 w-6 rounded-full opacity-50" style="animation: spin 1s linear infinite">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-loader-circle-icon lucide-loader-circle">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              </svg>
      </div>
    </div>
    <div id="loading" class="mt-8 space-y-5 hidden">
      <WordCardSkeleton />
      <div class="rounded-2xl border border-border bg-card shadow-sm animate-pulse p-5">
        <div class="h-5 w-48 rounded bg-muted mb-4"></div>
        <div class="space-y-3">
          <div class="h-4 w-full rounded bg-muted"></div>
          <div class="h-4 w-full rounded bg-muted"></div>
          <div class="h-4 w-3/4 rounded bg-muted"></div>
        </div>
      </div>
    </div>
    <div id="word-detail" class="hidden mt-8 space-y-10">
      <WordCard />
      <FrequencyTable />
    </div>
    <div id="error" class="hidden text-center py-16 text-muted-foreground text-base"></div>
  </main>
</BaseLayout>

<script>
  import { getTier } from "../../lib/tier";
  import { initSearch } from "../../lib/search";
  import { fillWordCard, initWordCardHandlers } from "../../lib/word-card";
  import { TIER_STYLE } from "../../lib/badges";

  interface WordEntry {
    reading: string;
    ririkkuRank: number;
    tier?: string;
    jlpt?: number;
    kaishi?: boolean;
    english?: string;
    ranks: Record<string, number>;
    detailRanks?: Record<string, number>;
  }

  // ─── DOM refs ───────────────────────────────────────────────────────────────

  const loadingSpinner = document.getElementById("loading-spinner")!;
  const loadingEl = document.getElementById("loading")!;
  const detailEl = document.getElementById("word-detail")!;
  const errorEl = document.getElementById("error")!;

  // ─── Init ───────────────────────────────────────────────────────────────────

  async function init() {
    const params = new URLSearchParams(window.location.search);
    const word = params.get("w");
    if (!word) {
      showError("No word specified. Use ?w=食べる");
      return;
    }

    document.title = `${word} — Japanese Word Frequency`;

    const skeletonTimer = setTimeout(() => {
      loadingSpinner.classList.add("hidden");
      loadingEl.classList.remove("hidden");
    }, 100);

    try {
      const firstChar = word.charAt(0);
      const res = await fetch(`${window.__BASE__}/api/words/${encodeURIComponent(firstChar)}/${encodeURIComponent(word)}.json`);
      clearTimeout(skeletonTimer);
      loadingSpinner.classList.add("hidden");
      if (!res.ok) {
        showError(`Word "${word}" not found.`);
        return;
      }
      const entries: WordEntry[] = await res.json();
      render(word, entries);
    } catch (err) {
      clearTimeout(skeletonTimer);
      loadingSpinner.classList.add("hidden");
      showError("Failed to load word data.");
      console.error(err);
    }
  }

  function showError(msg: string) {
    loadingSpinner.classList.add("hidden");
    loadingEl.classList.add("hidden");
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  // ─── Rendering ─────────────────────────────────────────────────────────────

  function render(word: string, entries: WordEntry[]) {
    const primary = entries[0];
    updateWordCard({ word, reading: primary.reading, jlpt: primary.jlpt, kaishi: primary.kaishi, ranks: primary.ranks, tier: primary.tier, english: primary.english });

    const allRanks: Record<string, number> = {};
    const ririkkuRanks: Record<string, number> = {};
    for (const entry of entries) {
      Object.assign(ririkkuRanks, entry.ranks);
      if (entry.detailRanks) Object.assign(allRanks, entry.detailRanks);
    }
    updateFrequencyTable(allRanks, ririkkuRanks);

    loadingEl.classList.add("hidden");
    detailEl.classList.remove("hidden");
  }

  // ─── Word Card ─────────────────────────────────────────────────────────────

  function updateWordCard(data: { word: string; reading: string; jlpt?: number; kaishi?: boolean; ranks?: Record<string, number>; tier?: string; english?: string }) {
    fillWordCard(detailEl.querySelector<HTMLElement>(".word-card")!, data);
  }

  // ─── Frequency Table ───────────────────────────────────────────────────────

  function getRank(columnId: string, ranks: Record<string, number>, ririkkuRanks: Record<string, number>): number {
    const r = ranks[columnId];
    if (columnId in ranks && r != null && !isNaN(r) && r !== -1) return r;
    const rr = ririkkuRanks[columnId];
    if (columnId in ririkkuRanks && rr != null && !isNaN(rr)) return rr;
    return -1;
  }

  function updateFrequencyTable(ranks: Record<string, number>, ririkkuRanks: Record<string, number>) {
    const rows = detailEl.querySelectorAll<HTMLElement>("[data-column-id]");
    for (const row of rows) {
      const columnId = row.dataset.columnId!;
      const rank = getRank(columnId, ranks, ririkkuRanks);
      const tier = getTier(rank);
      const isAbsent = rank === -1;
      const style = TIER_STYLE[tier] || TIER_STYLE.UNRANKED;

      const badge = row.querySelector<HTMLElement>("[data-tier-badge]")!;
      badge.className = `inline-flex items-center rounded-full px-2 sm:px-3 py-1 text-base`; // ${style.badge}
      badge.textContent = style.emoji;

      const rankCell = row.querySelector<HTMLElement>("[data-rank-cell]")!;
      rankCell.textContent = isAbsent ? "N/A" : rank.toLocaleString();
      rankCell.className = `py-2.5 px-3 sm:px-5 align-middle text-right tabular-nums text-sm ${isAbsent ? "text-muted-foreground/40" : "font-bold text-foreground"}`;
    }
  }

  // ─── Boot ─────────────────────────────────────────────────────────────────

  initWordCardHandlers();
  initSearch();
  init();
</script>
