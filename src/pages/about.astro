---
import BaseLayout from "../layouts/BaseLayout.astro";
import TitleHeader from "../components/TitleHeader.astro";
import { CREDITS } from "../lib/credits";
---

<BaseLayout title="About — Japanese Word Rank Lookup">
  <TitleHeader />
  <main class="page-content max-w-3xl mx-auto px-6 pt-18 pb-16">
    <h1 class="text-2xl font-bold mb-6">About</h1>
    <p class="text-sm text-muted-foreground mb-8">
      Japanese Word Rank Lookup is a free tool for looking up word frequency rankings across multiple Japanese language datasets. Search by kana, kanji, or romaji to see how common a word is across different corpora.
    </p>

    <p class="text-sm text-muted-foreground mb-8">
      For more comprehensive information, see <a href="https://github.com/PikaPikaGems/japanese-word-frequency" class="underline hover:text-foreground">PikaPikaGems/japanese-word-frequency</a> — a comprehensive collection of Japanese word frequency datasets, analysis scripts, and insights, consolidating datasets into unified formats for language learning, linguistics, and NLP research.
    </p>

    <h2 class="text-lg font-bold mb-4">Credits & Data Sources</h2>
    <p class="text-sm text-muted-foreground mb-4">
      This project would not be possible without the following open resources.
    </p>


    {CREDITS.map((section) => (
      <>
        <h3 class="text-sm font-bold mb-2">{section.title}</h3>
        {section.description && (
          <p class="text-sm text-muted-foreground mb-2">
            {section.description.text}{" "}
            {section.description.link && (
              <a href={section.description.link.url} class="underline hover:text-foreground">{section.description.link.name}</a>
            )}
          </p>
        )}
        {section.sources.length > 1 && (
          <p class="text-sm text-muted-foreground mb-1">Primary sources:</p>
        )}
        <ul class="list-disc list-inside text-sm text-muted-foreground mb-6 space-y-1">
          {section.sources.map((source) => (
            <li><a href={source.url} class="underline hover:text-foreground">{source.name}</a></li>
          ))}
        </ul>
      </>
    ))}

    <p class="text-sm text-muted-foreground">
      Built by <a href="https://github.com/PikaPikaGems" class="underline hover:text-foreground">PikaPikaGems</a>.
    </p>
  </main>
</BaseLayout>
